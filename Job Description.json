    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of items) {\n  const rawOutput = item?.json?.output;\n  if (!rawOutput || typeof rawOutput !== 'string') continue;\n\n  const cleaned = rawOutput\n    .replace(/```json/gi, '')\n    .replace(/```/g, '')\n    .trim();\n\n  let parsed;\n  try {\n    parsed = JSON.parse(cleaned);\n  } catch (e) {\n    throw new Error('Failed to parse AI JSON output: ' + e.message);\n  }\n\n  if (!Array.isArray(parsed)) {\n    throw new Error('Parsed AI output is not a JSON array');\n  }\n\n  for (const evaluation of parsed) {\n    results.push({\n      json: {\n        description: evaluation.description || \"Not specified in CV\",\n        total_experience: evaluation.total_experience || \"Not specified in CV\",\n        tech_stack:\n          typeof evaluation.tech_stack === 'object' && evaluation.tech_stack !== null\n            ? evaluation.tech_stack\n            : {},\n        candidate_strengths: evaluation.candidate_strengths || [],\n        candidate_weaknesses: evaluation.candidate_weaknesses || [],\n        risk_factor_level: evaluation.risk_factor_level || \"Not specified in CV\",\n        risk_factor: evaluation.risk_factor || \"Not specified in CV\",\n        reward_factor_level: evaluation.reward_factor_level || \"Not specified in CV\",\n        reward_factor: evaluation.reward_factor || \"Not specified in CV\",\n        fit_duration: evaluation.fit_duration || \"Not specified in CV\",\n        overall_fit_rating: typeof evaluation.overall_fit_rating === 'number'\n          ? evaluation.overall_fit_rating\n          : 0,\n        justification_for_rating: evaluation.justification_for_rating || \"Not specified in CV\"\n      }\n    });\n  }\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        288,
        16
      ],
      "id": "495bd5f8-fc3c-4b30-9e0e-81017a2f16de",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const newItems = [];\n\nfunction clean(text) {\n  if (typeof text !== 'string') return '';\n  return text.replace(/\\*\\*/g, '').trim();\n}\n\nfunction toBullets(list) {\n  if (!Array.isArray(list) || list.length === 0) return '';\n  return list.map(v => '• ' + clean(v)).join('\\n');\n}\n\nfunction formatTechStack(techStack) {\n  if (!techStack || typeof techStack !== 'object' || Array.isArray(techStack)) return '';\n\n  return Object.entries(techStack)\n    .filter(([_, values]) => Array.isArray(values) && values.length > 0)\n    .map(([heading, values]) => {\n      return `${heading}:\\n${values.map(v => '• ' + clean(v)).join('\\n')}`;\n    })\n    .join('\\n\\n');\n}\n\nfunction formatTotalExperience(exp) {\n  if (!exp || typeof exp !== 'object') return String(exp || 'Not specified in CV');\n  return [\n    exp.summary || '',\n    exp.relevance_to_role ? `Relevance: ${exp.relevance_to_role}` : '',\n    typeof exp.internship_months === 'number' ? `Internship: ${exp.internship_months} months` : '',\n    typeof exp.fulltime_months === 'number' ? `Full-time: ${exp.fulltime_months} months` : ''\n  ].filter(Boolean).join('\\n');\n}\n\nfor (const item of items) {\n  const strengths = item.json.candidate_strengths || [];\n  const weaknesses = item.json.candidate_weaknesses || [];\n\n  newItems.push({\n    json: {\n      description:                    item.json.description || 'Not specified in CV',\n      total_experience:               formatTotalExperience(item.json.total_experience),\n      tech_stack_formatted:           formatTechStack(item.json.tech_stack),\n      candidate_strengths_formatted:  toBullets(strengths),\n      candidate_weaknesses_formatted: toBullets(weaknesses),\n      risk_factor_level:              item.json.risk_factor_level || 'Not specified in CV',\n      risk_factor_explanation:        item.json.risk_factor || 'Not specified in CV',\n      reward_factor_level:            item.json.reward_factor_level || 'Not specified in CV',\n      reward_factor_explanation:      item.json.reward_factor || 'Not specified in CV',\n      fit_duration:                   item.json.fit_duration || 'Not specified in CV',\n      overall_fit_rating:             typeof item.json.overall_fit_rating === 'number'\n                                        ? item.json.overall_fit_rating\n                                        : 0,\n      justification:                  item.json.justification_for_rating || 'Not specified in CV'\n    }\n  });\n}\n\nreturn newItems;"
      },
